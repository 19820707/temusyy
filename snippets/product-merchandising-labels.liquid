{% comment %}
  Frictionless merchandising (tags + inventory). Flow tags map into lanes:
  - Popular: exact tag `popular` → product.merch.popular (separate from “Trending”)
  - Trending: `trending`, `tendencia`, `destaque`, `temusy-interesse`, `flow-interesse` (not the Popular tag)
  - Selling fast: handled in `product-urgency-badges.liquid` (same tags + optional metafields) to avoid duplicate chips.
  - Best seller: `bestseller`, `mais-vendido`, `mais vendido`, `temusy-vendas`, `flow-vendas`
  - Limited stock: Shopify inventory when qty ≤ low_stock_threshold (merch chip only when tags_only is false)
  See docs/shopify-flow-fase-8.md.
{% endcomment %}
{% liquid
  assign recently_viewed = recently_viewed | default: nil
  assign countdown_timer = countdown_timer | default: nil
  assign product_compare = product_compare | default: false
  assign tags_only = tags_only | default: false
  assign show_merch = true
  if recently_viewed or countdown_timer or product_compare
    assign show_merch = false
  endif
%}
{% if product and show_merch %}
  {% assign v = product.selected_or_first_available_variant %}
  {% assign low_ok = false %}
  {% if v.inventory_management == 'shopify' and v.inventory_quantity != nil %}
    {% if v.inventory_quantity > 0 and v.inventory_quantity <= settings.low_stock_threshold %}
      {% assign low_ok = true %}
    {% endif %}
  {% endif %}
  {% assign show_popular = false %}
  {% assign show_trending = false %}
  {% assign show_bestseller = false %}
  {% for tag in product.tags %}
    {% assign tl = tag | downcase | strip %}
    {% if tl == 'popular' %}
      {% assign show_popular = true %}
    {% elsif tl == 'trending' or tl == 'tendencia' or tl == 'destaque' or tl == 'temusy-interesse' or tl == 'flow-interesse' %}
      {% assign show_trending = true %}
    {% elsif tl == 'bestseller' or tl == 'mais-vendido' or tl == 'mais vendido' or tl == 'temusy-vendas' or tl == 'flow-vendas' %}
      {% assign show_bestseller = true %}
    {% endif %}
  {% endfor %}
  {% if show_popular or show_trending or show_bestseller or low_ok and tags_only == false %}
    <div class="productitem__merch-labels">
      {% if show_popular %}
        <span class="productitem__merch-label productitem__merch-label--popular">{{ 'product.merch.popular' | t }}</span>
      {% endif %}
      {% if show_trending %}
        <span class="productitem__merch-label productitem__merch-label--trending">🔥 {{ 'product.merch.trending' | t }}</span>
      {% endif %}
      {% if show_bestseller %}
        <span class="productitem__merch-label productitem__merch-label--bestseller">⭐ {{ 'product.merch.bestseller' | t }}</span>
      {% endif %}
      {% if low_ok and tags_only == false %}
        <span class="productitem__merch-label productitem__merch-label--scarcity">⚡ {{ 'product.merch.last_units' | t }}</span>
      {% endif %}
    </div>
  {% endif %}
{% endif %}
