/*
 * Homepage stack — system concept → section instance id:
 *   hero                 → homepage_hero
 *   deal_zone            → homepage_deal_zone
 *   trending_products    → homepage_best_sellers_products
 *   decision_shortcuts   → homepage_smart_hub
 *   trust_bar            → homepage_trust_bar
 *   category_grid        → homepage_trending_categories
 *   featured_products    → homepage_featured_products
 *   recently_viewed      → homepage_recently_viewed
 *   testimonials         → homepage_testimonials
 * Optional (not in this file): buy-zone strip, adaptive strip, extra recommended row — add in Theme Editor.
 */
{
  "sections": {
    "homepage_hero": {
      "type": "dynamic-slideshow",
      "blocks": {
        "slide-2": {
          "type": "slide",
          "settings": {
            "background_image": "shopify://shop_images/a-single-hand-holds-dropper-bottle.jpg",
            "title": "🔥 Best-selling beauty products",
            "text": "Rated 4.8 by customers",
            "color": "#222222",
            "link": "",
            "text_alignment": "left",
            "button_one_label": "Shop best-selling beauty",
            "button_one_link": "shopify://collections/health-and-beauty",
            "button_one_style": "primary",
            "button_two_label": "",
            "button_two_link": "",
            "button_two_style": "primary",
            "show_overlay": false,
            "overlay_color": "#000000",
            "overlay_opacity": 1
          }
        }
      },
      "block_order": [
        "slide-2"
      ],
      "settings": {
        "enable_autoplay": false,
        "autoplay_duration": 5,
        "slideshow_width": "content",
        "slideshow_height": "small",
        "slideshow_height_mobile": "small",
        "slideshow_text_below_image": true
      }
    },
    "homepage_deal_zone": {
      "type": "dynamic-temusy-deal-zone",
      "settings": {
        "heading": "Today's deals",
        "signal_nav_label": "Shopping benefits",
        "signal_one_label": "Choice picks",
        "signal_one_link": "shopify://collections/best-sellers",
        "signal_two_label": "Bundle savings",
        "signal_two_link": "shopify://collections/best-sellers",
        "signal_three_label": "Secure checkout",
        "signal_three_link": "",
        "signal_four_label": "Support ready",
        "signal_four_link": "shopify://pages/support",
        "show_bundle_lane": true,
        "bundle_title": "Bundle deals",
        "bundle_line": "3+ items - stack savings at checkout when your discount applies.",
        "bundle_link": "shopify://collections/best-sellers",
        "deals_rail_title": "Super deals",
        "show_countdown": true,
        "deadline_iso": "",
        "collection": "best-sellers",
        "product_count": 8,
        "cta_label": "View all deals",
        "cta_style": "primary",
        "background_color": "#f1f5f9",
        "text_color": "#0f172a",
        "accent_color": "#e11d48"
      }
    },
    "homepage_smart_hub": {
      "type": "dynamic-smart-homepage-hub",
      "blocks": {
        "lane_best_sellers": {
          "type": "collection_link",
          "settings": {
            "collection": "best-sellers",
            "link": "shopify://collections/best-sellers",
            "path_emoji": "",
            "chip_label": "Best sellers",
            "badge": "Hot",
            "title": "Best sellers",
            "text": ""
          }
        },
        "lane_gifts": {
          "type": "collection_link",
          "settings": {
            "collection": "toys-and-games",
            "link": "shopify://collections/toys-and-games",
            "path_emoji": "",
            "chip_label": "Gifts",
            "badge": "Gift-ready",
            "title": "Gifts",
            "text": ""
          }
        },
        "lane_under_50": {
          "type": "collection_link",
          "settings": {
            "collection": "under-50",
            "link": "shopify://collections/under-50",
            "path_emoji": "",
            "chip_label": "Under $50",
            "badge": "Value",
            "title": "Under $50",
            "text": ""
          }
        },
        "lane_new_arrivals": {
          "type": "collection_link",
          "settings": {
            "collection": "new-arrivals",
            "link": "shopify://collections/new-arrivals",
            "path_emoji": "",
            "chip_label": "Trending",
            "badge": "Just in",
            "title": "Trending",
            "text": ""
          }
        },
        "lane_support": {
          "type": "trust_point",
          "settings": {
            "title": "Support",
            "text": ""
          }
        },
        "intent_watch_under50": {
          "type": "search_intent_hint",
          "settings": {
            "keywords": "watch, watches, relogio",
            "label": "Watches under $50",
            "link": "shopify://collections/under-50"
          }
        },
        "intent_watch_premium": {
          "type": "search_intent_hint",
          "settings": {
            "keywords": "watch, watches, relogio",
            "label": "Premium watches",
            "link": "shopify://collections/watches"
          }
        },
        "intent_watch_bestsellers": {
          "type": "search_intent_hint",
          "settings": {
            "keywords": "watch, watches, relogio",
            "label": "Best sellers",
            "link": "shopify://collections/best-sellers"
          }
        }
      },
      "block_order": [
        "lane_gifts",
        "lane_new_arrivals",
        "lane_under_50",
        "lane_best_sellers",
        "lane_support",
        "intent_watch_under50",
        "intent_watch_premium",
        "intent_watch_bestsellers"
      ],
      "settings": {
        "kicker": "",
        "title": "Shop flow — faster by need",
        "text": "",
        "search_placeholder": "Search products",
        "search_button": "Go",
        "primary_label": "Best sellers",
        "primary_link": "shopify://collections/best-sellers",
        "secondary_label": "Under $50",
        "secondary_link": "shopify://collections/under-50",
        "tertiary_label": "Trending now",
        "tertiary_link": "shopify://collections/new-arrivals",
        "paths_layout": "path_chips",
        "panel_label": "Shop paths",
        "search_shortcuts_a11y_label": "Categories",
        "search_intents_heading": "Quick picks"
      }
    },
    "homepage_best_sellers_products": {
      "type": "dynamic-featured-collection",
      "settings": {
        "title": "This week's top sellers",
        "layout": "grid",
        "mobile_layout": "grid",
        "collection": "best-sellers",
        "product_count": 8,
        "cta_label": "See offer picks in this row",
        "cta_button_style": "primary",
        "temusy_intent_zone": "buy"
      }
    },
    "homepage_trending_categories": {
      "type": "dynamic-collection-list",
      "blocks": {
        "intent_gifts_under_50": {
          "type": "collection",
          "settings": {
            "collection": "under-50",
            "image": "shopify://shop_images/toy-drive-donation-box.jpg",
            "title": "Under $50"
          }
        },
        "intent_best_sellers": {
          "type": "collection",
          "settings": {
            "collection": "best-sellers",
            "image": "shopify://shop_images/loafers-leaning-along-white-wall.jpg",
            "title": "Best sellers"
          }
        },
        "intent_new_arrivals": {
          "type": "collection",
          "settings": {
            "collection": "new-arrivals",
            "image": "shopify://shop_images/woman-listening-to-music.jpg",
            "title": "New"
          }
        }
      },
      "block_order": [
        "intent_gifts_under_50",
        "intent_best_sellers",
        "intent_new_arrivals"
      ],
      "settings": {
        "title": "Quick paths",
        "thumbnail_columns_desktop": 3,
        "thumbnail_columns_mobile": 2,
        "image-crop": "circle",
        "cta_label": "See all",
        "cta_link": "shopify://collections/all",
        "cta_button_style": "primary"
      }
    },
    "homepage_trust_bar": {
      "type": "dynamic-highlights-banner",
      "blocks": {
        "highlight_proof_12k": {
          "type": "highlight",
          "settings": {
            "icon": "icon-delivery-package",
            "title": "✔ Free shipping",
            "text": "<p>Policy: shipping regions &amp; rates.</p>",
            "link": "/policies/shipping-policy"
          }
        },
        "highlight_qVfTeb": {
          "type": "highlight",
          "settings": {
            "icon": "icon-label-tag",
            "title": "✔ Easy returns",
            "text": "<p>Policy: returns &amp; eligibility.</p>",
            "link": "/policies/refund-policy"
          }
        },
        "highlight_zfgA7r": {
          "type": "highlight",
          "settings": {
            "icon": "icon-lock",
            "title": "✔ Secure checkout",
            "text": "<p>Secure checkout &amp; encryption.</p>",
            "link": ""
          }
        },
        "highlight_EjpTGH": {
          "type": "highlight",
          "settings": {
            "icon": "icon-chat-alternate",
            "title": "✔ 24/7 support",
            "text": "<p>Support link below.</p>",
            "link": "shopify://pages/support"
          }
        }
      },
      "block_order": [
        "highlight_proof_12k",
        "highlight_qVfTeb",
        "highlight_zfgA7r",
        "highlight_EjpTGH"
      ],
      "settings": {
        "section_spacing": true,
        "section_width": "full-width",
        "icon_layout": "left",
        "color": "#f1f5f9",
        "icon_color": "#5eead4",
        "background_color": "#0f172a",
        "mobile_layout": "grid"
      }
    },
    "homepage_featured_products": {
      "type": "dynamic-featured-collection",
      "settings": {
        "title": "Jewelry our team wears",
        "layout": "grid",
        "mobile_layout": "grid",
        "collection": "jewelry-and-fashion-accessories",
        "product_count": 8,
        "cta_label": "See offer picks in this edit",
        "cta_button_style": "secondary",
        "temusy_intent_zone": "buy"
      }
    },
    "homepage_recently_viewed": {
      "type": "static-recently-viewed",
      "settings": {
        "enable_recently_viewed_products": true
      }
    },
    "homepage_testimonials": {
      "type": "dynamic-testimonials",
      "blocks": {
        "testimonial-1": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/man-reaches-inside-his-jacket.jpg",
            "star_rating": "5",
            "text": "<p><strong>An elegant and reliable watch, clearly crafted to last. Prompt delivery and refined packaging added to a smooth, premium experience. Highly recommended for those who appreciate quality and style.</strong></p>",
            "author": "<p><em><strong>Jonathan Reed</strong></em></p>"
          }
        },
        "testimonial-2": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/loafers-leaning-along-white-wall.jpg",
            "star_rating": "5",
            "text": "<p><strong>Impressive quality and classic design. These loafers are as comfortable as they are stylish. The unboxing experience matched the premium look and feel.</strong></p>",
            "author": "<p><em><strong>Oliver Grant</strong></em></p>"
          }
        },
        "testimonial-3": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/woman-listening-to-music.jpg",
            "star_rating": "5",
            "text": "<p><strong>Crisp sound, seamless Bluetooth connection, and a comfortable fit. These earbuds exceeded expectations. Delivery was prompt and packaging felt premium.</strong></p>",
            "author": "<p><em><strong>Sophia Lane</strong></em></p>"
          }
        },
        "testimonial-4": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/pink-lip-gloss.jpg",
            "star_rating": "5",
            "text": "<p><strong>A modern, refined scent that works perfectly for day or evening. The fragrance has depth and longevity. Excellent customer care and presentation.</strong></p>",
            "author": "<p><em><strong>Alex Whitmore</strong></em></p>"
          }
        }
      },
      "block_order": [
        "testimonial-1",
        "testimonial-2",
        "testimonial-3",
        "testimonial-4"
      ],
      "settings": {
        "title": "What buyers said (with photos)",
        "image_crop": "circle",
        "text_size": "small"
      }
    }
  },
  "order": [
    "homepage_hero",
    "homepage_deal_zone",
    "homepage_best_sellers_products",
    "homepage_smart_hub",
    "homepage_trust_bar",
    "homepage_trending_categories",
    "homepage_featured_products",
    "homepage_recently_viewed",
    "homepage_testimonials"
  ]
}
