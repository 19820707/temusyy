<script
  type="application/json"
  data-section-id="{{ section.id }}"
  data-section-type="static-announcement">
</script>

{% liquid
  assign micro_preset = section.settings.temusy_micro_reward_preset | default: 'custom'
  assign announcement_desktop = section.settings.announcement_text | strip
  assign announcement_mobile = section.settings.announcement_text_mobile | strip
  if micro_preset == 'discount_today'
    assign announcement_desktop = 'general.temusy_micro_reward.discount_desktop' | t
    assign announcement_mobile = 'general.temusy_micro_reward.discount_mobile' | t
  elsif micro_preset == 'free_shipping_today'
    assign announcement_desktop = 'general.temusy_micro_reward.shipping_desktop' | t
    assign announcement_mobile = 'general.temusy_micro_reward.shipping_mobile' | t
  endif
%}

{% assign show_everywhere = false %}
{% assign homepage_only = false %}

{% if
  section.settings.show_announcement and
  section.settings.homepage_announcement == false
%}
  {% assign show_everywhere = true %}
{% endif %}

{% if
  section.settings.show_announcement and
  section.settings.homepage_announcement and
  template == 'index'
%}
  {% assign homepage_only = true %}
{% endif %}

{% if show_everywhere or homepage_only %}
  {% if announcement_desktop != blank or announcement_mobile != blank %}
    <div
      class="
        announcement-bar
        {% if announcement_desktop == blank and announcement_mobile != blank %}
          only-mobile
        {% endif %}
      "
      style="
        color: {{ section.settings.announcement_color }};
        background: {{ section.settings.announcement_background }};
      "
      data-announcement-bar
    >
      {% if section.settings.announcement_link != blank %}
        <a
          class="announcement-bar-link"
          href="{{ section.settings.announcement_link }}"
          ></a>
      {% endif %}

      {% if announcement_desktop != blank %}
        <div class="announcement-bar-text">
          {{ announcement_desktop }}
        </div>
      {% endif %}

      <div class="announcement-bar-text-mobile">
        {% if announcement_mobile != blank %}
          {{ announcement_mobile }}
        {% else %}
          {{ announcement_desktop }}
        {% endif %}
      </div>
    </div>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "t:sections.announcement_bar.name",
  "class": "site-announcement",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.announcement_bar.header_1.content"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "t:sections.announcement_bar.show_announcement.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "homepage_announcement",
      "label": "t:sections.announcement_bar.homepage_announcement.label",
      "default": false
    },
    {
      "type": "select",
      "id": "temusy_micro_reward_preset",
      "label": "t:sections.announcement_bar.temusy_micro_reward_preset.label",
      "info": "t:sections.announcement_bar.temusy_micro_reward_preset.info",
      "default": "discount_today",
      "options": [
        {
          "value": "discount_today",
          "label": "t:sections.announcement_bar.temusy_micro_reward_preset.option_discount"
        },
        {
          "value": "free_shipping_today",
          "label": "t:sections.announcement_bar.temusy_micro_reward_preset.option_shipping"
        },
        {
          "value": "custom",
          "label": "t:sections.announcement_bar.temusy_micro_reward_preset.option_custom"
        }
      ]
    },
    {
      "id": "announcement_text",
      "type": "textarea",
      "label": "t:sections.announcement_bar.announcement_text.label",
      "default": "Announce something here"
    },
    {
      "id": "announcement_text_mobile",
      "type": "textarea",
      "label": "t:sections.announcement_bar.announcement_text_mobile.label",
      "info": "t:sections.announcement_bar.announcement_text_mobile.info"
    },
    {
      "id": "announcement_link",
      "type": "url",
      "label": "t:sections.announcement_bar.announcement_link.label"
    },
    {
      "id": "announcement_color",
      "type": "color",
      "label": "t:sections.announcement_bar.announcement_color.label",
      "default": "#000000"
    },
    {
      "id": "announcement_background",
      "type": "color",
      "label": "t:sections.announcement_bar.announcement_background.label",
      "default": "#f5f3ed"
    }
  ]
}

{% endschema %}