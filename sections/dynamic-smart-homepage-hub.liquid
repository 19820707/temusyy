{% comment %}
  Invariants:
  - Homepage guidance must remain usable without JavaScript or app embeds.
  - Search and collection links must be explicit, crawlable, and keyboard-friendly (focus-visible rings on cards + buttons).
  - Curated search intent hints ship as a template-element JSON payload (no inline JS in this file); typing behaviour is wired from snippets/temusy-intent-detection.liquid on the index template only.
  - Copy must guide shopping intent without claiming unavailable inventory or delivery promises.
  - This file must ship with the theme: templates/index.json uses section id "homepage_smart_hub" with type "dynamic-smart-homepage-hub".
    If you remove it, replace the section in the Theme Editor (see docs/homepage-section-dependencies.md).
{% endcomment %}
{% liquid
  assign title = section.settings.title | default: 'Shop flow automático'
  assign text = section.settings.text | default: ''
  assign search_placeholder = section.settings.search_placeholder | default: 'Search products'
  assign search_button = section.settings.search_button | default: 'Go'
  assign primary_label = section.settings.primary_label | default: 'Best sellers'
  assign primary_link = section.settings.primary_link | default: ''
  assign secondary_label = section.settings.secondary_label | default: 'Under $50'
  assign secondary_link = section.settings.secondary_link | default: ''
  assign tertiary_label = section.settings.tertiary_label | default: 'Trending now'
  assign tertiary_link = section.settings.tertiary_link | default: ''
%}

<section
  class="smart-homepage-hub{% if section.settings.paths_layout == 'path_chips' %} smart-homepage-hub--path-chips{% endif %}"
  data-temusy-intent-zone="guides"
  aria-labelledby="smart-homepage-hub-title-{{ section.id }}"
>
  <div class="smart-homepage-hub__inner">
    <div class="smart-homepage-hub__content">
      {% if section.settings.kicker != blank %}
        <p class="smart-homepage-hub__kicker">{{ section.settings.kicker }}</p>
      {% endif %}

      <h2 class="smart-homepage-hub__title" id="smart-homepage-hub-title-{{ section.id }}">
        {{ title }}
      </h2>

      <ul class="smart-homepage-hub__market-signals" aria-label="Shopping signals">
        <li>
          <strong>Deals</strong>
          <span>Timed picks</span>
        </li>
        <li>
          <strong>Paths</strong>
          <span>Fewer taps</span>
        </li>
        <li>
          <strong>Support</strong>
          <span>Order help</span>
        </li>
      </ul>

      {% if text != blank %}
        <div class="smart-homepage-hub__text rte">
          {{ text }}
        </div>
      {% endif %}

      {% liquid
        assign intent_valid_count = 0
        for block in section.blocks
          if block.type == 'search_intent_hint'
            assign _ikw = block.settings.keywords | default: '' | strip
            assign _ilb = block.settings.label | default: '' | strip
            assign _ilk = block.settings.link | default: '' | strip
            if _ikw != blank and _ilb != blank and _ilk != blank
              assign intent_valid_count = intent_valid_count | plus: 1
            endif
          endif
        endfor
      %}
      <div
        class="smart-homepage-hub__search-wrap"
        {% if intent_valid_count > 0 %}
          data-temusy-hub-search-wrap="{{ section.id }}"
        {% endif %}
      >
        <form class="smart-homepage-hub__search" action="{{ routes.search_url }}" method="get" role="search">
          <label class="visually-hidden" for="smart-homepage-search-{{ section.id }}">
            {{ 'search.form.placeholder' | t }}
          </label>
          <input
            class="smart-homepage-hub__search-input"
            id="smart-homepage-search-{{ section.id }}"
            {% if intent_valid_count > 0 %}
              data-temusy-hub-search-input
              aria-controls="smart-homepage-search-intents-{{ section.id }}"
              aria-autocomplete="list"
            {% endif %}
            type="search"
            name="q"
            value="{{ search.terms | escape }}"
            placeholder="{{ search_placeholder | escape }}"
            autocomplete="off"
          >
          <button class="smart-homepage-hub__search-button" type="submit">
            {{ search_button }}
          </button>
        </form>

        {% if intent_valid_count > 0 %}
          <div
            id="smart-homepage-search-intents-{{ section.id }}"
            class="smart-homepage-hub__search-intents"
            role="region"
            aria-live="polite"
            aria-label="{{ section.settings.search_intents_heading | default: 'Quick picks' | escape }}"
            hidden
          >
            <p class="smart-homepage-hub__search-intents-kicker">
              {{ section.settings.search_intents_heading | default: 'Quick picks' | escape }}
            </p>
            <ul class="smart-homepage-hub__search-intents-list" data-temusy-search-intents-list></ul>
          </div>

          <template data-temusy-hub-intents="{{ section.id }}">
            [
            {%- assign needs_comma = false -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'search_intent_hint' -%}
                {%- assign kws = block.settings.keywords | default: '' | strip -%}
                {%- assign lbl = block.settings.label | default: '' | strip -%}
                {%- assign lnk = block.settings.link | default: '' | strip -%}
                {%- if kws != blank and lbl != blank and lnk != blank -%}
                  {%- if needs_comma -%},{%- endif -%}
                  {"keywords":{{ kws | json }},"label":{{ lbl | json }},"url":{{ lnk | json }}}
                  {%- assign needs_comma = true -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            ]
          </template>
        {% endif %}
      </div>

      {% liquid
        assign shortcut_count = 0
        for block in section.blocks
          if block.type == 'search_shortcut'
            assign sc = collections[block.settings.collection]
            assign surl = block.settings.link
            if surl == blank and sc != blank
              assign surl = sc.url
            endif
            assign slab = block.settings.label
            if slab == blank and sc != blank
              assign slab = sc.title
            endif
            if surl != blank and slab != blank
              assign shortcut_count = shortcut_count | plus: 1
            endif
          endif
        endfor
      %}
      {% if shortcut_count > 0 %}
        <nav
          class="smart-homepage-hub__shortcuts"
          aria-label="{{ section.settings.search_shortcuts_a11y_label | default: 'Jump to a category' | escape }}"
        >
          {% for block in section.blocks %}
            {% if block.type == 'search_shortcut' %}
              {% assign sc = collections[block.settings.collection] %}
              {% assign surl = block.settings.link %}
              {% if surl == blank and sc != blank %}
                {% assign surl = sc.url %}
              {% endif %}
              {% assign slab = block.settings.label %}
              {% if slab == blank and sc != blank %}
                {% assign slab = sc.title %}
              {% endif %}
              {% if surl != blank and slab != blank %}
                <a class="smart-homepage-hub__shortcut" href="{{ surl }}" {{ block.shopify_attributes }}>
                  {{- slab | escape -}}
                </a>
              {% endif %}
            {% endif %}
          {% endfor %}
        </nav>
      {% endif %}

      <div class="smart-homepage-hub__actions">
        {% if primary_label != blank and primary_link != blank %}
          <a class="smart-homepage-hub__button smart-homepage-hub__button--primary" href="{{ primary_link }}">
            {{ primary_label }}
          </a>
        {% endif %}
        {% if secondary_label != blank and secondary_link != blank %}
          <a class="smart-homepage-hub__button smart-homepage-hub__button--secondary" href="{{ secondary_link }}">
            {{ secondary_label }}
          </a>
        {% endif %}
        {% if tertiary_label != blank and tertiary_link != blank %}
          <a class="smart-homepage-hub__button smart-homepage-hub__button--tertiary" href="{{ tertiary_link }}">
            {{ tertiary_label }}
          </a>
        {% endif %}
      </div>
    </div>

    {% liquid
      assign panel_block_count = 0
      for block in section.blocks
        if block.type == 'collection_link' or block.type == 'trust_point'
          assign panel_block_count = panel_block_count | plus: 1
        endif
      endfor
    %}
    {% if panel_block_count > 0 %}
      <div
        class="smart-homepage-hub__panel{% if section.settings.paths_layout == 'path_chips' %} smart-homepage-hub__panel--chips{% endif %}"
        aria-label="{{ section.settings.panel_label | escape }}"
      >
        {% if section.settings.paths_layout == 'path_chips' %}
          <div class="smart-homepage-hub__paths-row" role="list" data-temusy-hub-paths>
            {% for block in section.blocks %}
              {% if block.type == 'collection_link' %}
                {% assign collection = collections[block.settings.collection] %}
                {% assign block_title = block.settings.title %}
                {% assign block_url = block.settings.link %}
                {% if block_url == blank and collection != blank %}
                  {% assign block_url = collection.url %}
                {% endif %}
                {% if block_title == blank and collection != blank %}
                  {% assign block_title = collection.title %}
                {% endif %}
                {% assign chip_label = block.settings.chip_label | default: block_title %}
                {% assign chip_badge = block.settings.badge | default: '' | strip %}
                {% if block_url != blank and chip_label != blank %}
                  {% liquid
                    assign chip_aria = chip_label
                    if chip_badge != blank
                      assign chip_aria = chip_aria | append: ' — ' | append: chip_badge
                    endif
                    if block.settings.text != blank
                      assign chip_desc = block.settings.text | strip_html | strip
                      if chip_desc != blank
                        assign chip_aria = chip_aria | append: ' — ' | append: chip_desc
                      endif
                    endif
                  %}
                  <a
                    class="smart-homepage-hub__path-chip{% if chip_badge != blank %} smart-homepage-hub__path-chip--badged{% endif %}"
                    href="{{ block_url }}"
                    data-temusy-interest="{{ block.settings.collection | escape }}"
                    role="listitem"
                    aria-label="{{ chip_aria | escape }}"
                    {{ block.shopify_attributes }}
                  >
                    {% if block.settings.path_emoji != blank %}
                      <span class="smart-homepage-hub__path-chip-emoji" aria-hidden="true">{{ block.settings.path_emoji }}</span>
                    {% endif %}
                    <span class="smart-homepage-hub__path-chip-stack">
                      {% if chip_badge != blank %}
                        <span class="smart-homepage-hub__path-chip-badge">{{ chip_badge | escape }}</span>
                      {% endif %}
                      <span class="smart-homepage-hub__path-chip-label">{{ chip_label | escape }}</span>
                    </span>
                  </a>
                {% endif %}
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}

        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'collection_link' %}
              {% if section.settings.paths_layout != 'path_chips' %}
                {% assign collection = collections[block.settings.collection] %}
                {% assign block_title = block.settings.title %}
                {% assign block_url = block.settings.link %}
                {% if block_url == blank and collection != blank %}
                  {% assign block_url = collection.url %}
                {% endif %}
                {% if block_title == blank and collection != blank %}
                  {% assign block_title = collection.title %}
                {% endif %}
                {% if block_url != blank and block_title != blank %}
                  <a
                    class="smart-homepage-hub__card"
                    href="{{ block_url }}"
                    data-temusy-interest="{{ block.settings.collection | escape }}"
                    {{ block.shopify_attributes }}
                  >
                    {% if block.settings.badge != blank %}
                      <span class="smart-homepage-hub__badge">{{ block.settings.badge }}</span>
                    {% endif %}
                    <span class="smart-homepage-hub__card-title">{{ block_title }}</span>
                    {% if block.settings.text != blank %}
                      <span class="smart-homepage-hub__card-text">{{ block.settings.text }}</span>
                    {% endif %}
                  </a>
                {% endif %}
              {% endif %}
            {% when 'trust_point' %}
              <div
                class="smart-homepage-hub__trust{% if section.settings.paths_layout == 'path_chips' %} smart-homepage-hub__trust--below-chips{% endif %}"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.title != blank %}
                  <strong>{{ block.settings.title }}</strong>
                {% endif %}
                {% if block.settings.text != blank %}
                  <span>{{ block.settings.text }}</span>
                {% endif %}
              </div>
            {% when 'search_shortcut' %}
            {% when 'search_intent_hint' %}
          {% endcase %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .smart-homepage-hub {
    --th-accent: {{ settings.color_links }};
    --th-heading: {{ settings.color_headings }};
    --th-body: {{ settings.color_text }};
    --th-page-bg: {{ settings.color_background }};
    --th-surface: {{ settings.color_input_background }};
    --th-border: {{ settings.color_input_border }};
    --th-btn-bg: {{ settings.color_button_background }};
    --th-btn-fg: {{ settings.color_button_text }};
    background: #ffffff;
    color: var(--th-heading);
    font-family: var(--theme-font-body), sans-serif;
    padding: 16px 14px 24px;
  }

  .smart-homepage-hub__inner {
    display: grid;
    gap: 18px;
    margin: 0 auto;
    max-width: 1280px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 8px;
    box-shadow: 0 6px 24px rgba(15, 23, 42, 0.06);
    padding: 16px;
  }

  .smart-homepage-hub__content,
  .smart-homepage-hub__panel {
    min-width: 0;
  }

  .smart-homepage-hub__kicker {
    color: var(--th-accent);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0;
    margin: 0 0 8px;
    text-transform: uppercase;
  }

  .smart-homepage-hub__title {
    color: var(--th-heading);
    font-family: var(--theme-font-heading), sans-serif;
    font-size: 1.45rem;
    line-height: 1.12;
    margin: 0;
  }

  .smart-homepage-hub__text {
    color: var(--th-body);
    font-size: 0.98rem;
    line-height: 1.45;
    margin-top: 10px;
    max-width: 72ch;
  }

  .smart-homepage-hub__market-signals {
    display: grid;
    gap: 8px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    list-style: none;
    margin: 12px 0 0;
    padding: 0;
  }

  .smart-homepage-hub__market-signals li {
    background: rgba(15, 23, 42, 0.035);
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 8px;
    display: grid;
    gap: 2px;
    margin: 0;
    min-width: 0;
    padding: 9px 10px;
  }

  .smart-homepage-hub__market-signals strong {
    color: var(--th-heading);
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1.1;
  }

  .smart-homepage-hub__market-signals span {
    color: var(--th-body);
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .smart-homepage-hub__search-wrap {
    display: grid;
    gap: 8px;
    margin-top: 12px;
  }

  .smart-homepage-hub__search {
    display: grid;
    gap: 8px;
    margin-top: 0;
  }

  .smart-homepage-hub__search-intents {
    background: var(--th-surface);
    border: 1px solid var(--th-border);
    border-radius: 8px;
    padding: 12px 14px 14px;
  }

  .smart-homepage-hub__search-intents-kicker {
    color: var(--th-body);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin: 0 0 8px;
    text-transform: uppercase;
  }

  .smart-homepage-hub__search-intents-list {
    display: grid;
    gap: 6px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .smart-homepage-hub__search-intents-list li {
    margin: 0;
  }

  .smart-homepage-hub__search-intents-link {
    align-items: center;
    color: var(--th-accent);
    display: inline-flex;
    font-size: 0.95rem;
    font-weight: 700;
    gap: 8px;
    line-height: 1.35;
    text-decoration: none;
  }

  .smart-homepage-hub__search-intents-link::before {
    color: var(--th-heading);
    content: '\2192';
    flex-shrink: 0;
    font-weight: 800;
  }

  .smart-homepage-hub__search-intents-link:hover,
  .smart-homepage-hub__search-intents-link:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .smart-homepage-hub__search-intents-link:focus-visible {
    outline: 2px solid var(--th-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .smart-homepage-hub__shortcuts {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .smart-homepage-hub__shortcut {
    background: var(--th-surface);
    border: 1px solid var(--th-border);
    border-radius: 999px;
    color: var(--th-heading);
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.2;
    padding: 7px 14px;
    text-decoration: none;
  }

  .smart-homepage-hub__shortcut:hover,
  .smart-homepage-hub__shortcut:focus-visible {
    border-color: var(--th-accent);
    color: var(--th-accent);
  }

  .smart-homepage-hub__shortcut:focus-visible {
    outline: 2px solid var(--th-accent);
    outline-offset: 2px;
  }

  .smart-homepage-hub__search-input {
    background: var(--th-surface);
    border: 1px solid var(--th-border);
    border-radius: 6px;
    color: var(--th-heading);
    min-height: 48px;
    padding: 0 14px;
    width: 100%;
  }

  .smart-homepage-hub__search-button,
  .smart-homepage-hub__button {
    align-items: center;
    border-radius: 8px;
    display: inline-flex;
    font-family: var(--theme-font-button), sans-serif;
    font-weight: 700;
    justify-content: center;
    min-height: 48px;
    padding: 0 16px;
    text-decoration: none;
  }

  .smart-homepage-hub__search-button,
  .smart-homepage-hub__button--primary {
    background: var(--th-btn-bg);
    border: 1px solid var(--th-btn-bg);
    color: var(--th-btn-fg);
  }

  .smart-homepage-hub__button--secondary {
    background: var(--th-surface);
    border: 1px solid var(--th-border);
    color: var(--th-heading);
  }

  .smart-homepage-hub__button--tertiary {
    background: transparent;
    border: 1px dashed var(--th-border);
    color: var(--th-heading);
  }

  .smart-homepage-hub__button--tertiary:hover {
    border-color: var(--th-accent);
    color: var(--th-accent);
  }

  .smart-homepage-hub__search-input:focus-visible {
    border-color: var(--th-accent);
    outline: 2px solid var(--th-accent);
    outline-offset: 2px;
  }

  .smart-homepage-hub__search-button:focus-visible,
  .smart-homepage-hub__button:focus-visible {
    outline: 2px solid var(--th-accent);
    outline-offset: 2px;
  }

  .smart-homepage-hub__card:focus-visible {
    border-color: var(--th-accent);
    outline: 2px solid var(--th-accent);
    outline-offset: 2px;
  }

  .smart-homepage-hub__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 14px;
  }

  .smart-homepage-hub__panel {
    display: grid;
    gap: 10px;
  }

  .smart-homepage-hub__panel--chips {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .smart-homepage-hub__paths-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .smart-homepage-hub__path-chip {
    align-items: center;
    background: var(--th-surface);
    border: 1px solid var(--th-border);
    border-radius: 8px;
    color: var(--th-heading);
    display: inline-flex;
    flex: 1 1 138px;
    font-size: 0.92rem;
    font-weight: 800;
    gap: 8px;
    line-height: 1.2;
    min-height: 50px;
    padding: 9px 12px;
    text-decoration: none;
  }

  .smart-homepage-hub__path-chip-emoji {
    font-size: 1.15rem;
    line-height: 1;
  }

  .smart-homepage-hub__path-chip-stack {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    line-height: 1.15;
    text-align: left;
  }

  .smart-homepage-hub__path-chip-badge {
    color: var(--th-accent);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .smart-homepage-hub__path-chip-label {
    white-space: nowrap;
  }

  .smart-homepage-hub__path-chip--badged {
    padding-top: 7px;
    padding-bottom: 7px;
  }

  .smart-homepage-hub__path-chip:hover,
  .smart-homepage-hub__path-chip:focus-visible {
    border-color: var(--th-accent);
    color: var(--th-accent);
  }

  .smart-homepage-hub__path-chip:focus-visible {
    outline: 2px solid var(--th-accent);
    outline-offset: 2px;
  }

  .smart-homepage-hub__trust--below-chips {
    border: 1px solid var(--th-border);
    border-radius: 8px;
    padding: 12px 14px;
    background: rgba(15, 23, 42, 0.03);
  }

  .smart-homepage-hub__card,
  .smart-homepage-hub__trust {
    background: var(--th-surface);
    border: 1px solid var(--th-border);
    border-radius: 8px;
    display: grid;
    gap: 5px;
    padding: 11px 12px;
    text-decoration: none;
  }

  .smart-homepage-hub__badge {
    color: var(--th-accent);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .smart-homepage-hub__card-title,
  .smart-homepage-hub__trust strong {
    color: var(--th-heading);
    font-weight: 800;
  }

  .smart-homepage-hub__card-text,
  .smart-homepage-hub__trust span {
    color: var(--th-body);
    font-size: 0.92rem;
  }

  @media screen and (min-width: 720px) {
    .smart-homepage-hub {
      padding: 20px 20px 30px;
    }

    .smart-homepage-hub__inner {
      align-items: center;
      grid-template-columns: minmax(0, 1fr) minmax(300px, 0.88fr);
      padding: 22px;
    }

    .smart-homepage-hub__search {
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .smart-homepage-hub__panel:not(.smart-homepage-hub__panel--chips) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>

{% schema %}
{
  "name": "Smart homepage hub",
  "class": "smart-homepage-hub-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "",
      "info": "Optional. Leave blank—extra labels slow the first tap."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Shop flow automático"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": ""
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search products"
    },
    {
      "type": "text",
      "id": "search_button",
      "label": "Search button",
      "default": "Go"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Best sellers",
      "info": "Decision label (not “Shop now”). Link to a real collection."
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
