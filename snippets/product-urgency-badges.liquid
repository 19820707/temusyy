{% comment %}
  Snippet: product-urgency-badges.liquid — compact urgency row (grids, PDP, buy zone, etc.).
  - “Only N left”: Shopify tracked inventory when quantity is 1..low_stock_threshold (honest threshold).
  - PDP mode (`pdp: true`): one pill per low-stock variant, each tagged `data-stock-level` + `data-stock-variant-id`
    so ProductDetails._updateStockLevels keeps the visible pill in sync with the selected variant.
  - “In N carts”: integer metafield `custom.active_carts` only (app/Flow — never fake in Liquid).
  - “Selling fast”: tags `selling-fast` / `selling fast` / `temusy-selling-fast`, OR boolean `custom.selling_fast`.
  Theme setting: `settings.temusy_product_urgency_badges` (defaults on in schema).
  Display order: stock → carts → selling fast.
{% endcomment %}
{% liquid
  assign recently_viewed = recently_viewed | default: nil
  assign countdown_timer = countdown_timer | default: nil
  assign product_compare = product_compare | default: false
  assign pdp = pdp | default: false
  assign base_variant = variant | default: product.selected_or_first_available_variant
  assign badges_on = true
  if settings.temusy_product_urgency_badges == false
    assign badges_on = false
  endif
%}
{% if badges_on and product and recently_viewed == nil and countdown_timer == nil and product_compare == false %}
  {% assign show_only_left = false %}
  {% assign only_left_n = 0 %}
  {% if pdp == false %}
    {% if base_variant.inventory_management == 'shopify' and base_variant.inventory_quantity != nil %}
      {% if base_variant.inventory_quantity > 0 and base_variant.inventory_quantity <= settings.low_stock_threshold %}
        {% assign show_only_left = true %}
        {% assign only_left_n = base_variant.inventory_quantity %}
      {% endif %}
    {% endif %}
  {% endif %}

  {% assign pdp_has_low_stock = false %}
  {% if pdp %}
    {% for v in product.variants %}
      {% if v.inventory_management == 'shopify' and v.inventory_quantity != nil %}
        {% if v.inventory_quantity > 0 and v.inventory_quantity <= settings.low_stock_threshold %}
          {% assign pdp_has_low_stock = true %}
          {% break %}
        {% endif %}
      {% endif %}
    {% endfor %}
  {% endif %}

  {% assign show_selling_fast = false %}
  {% for tag in product.tags %}
    {% assign tl = tag | downcase | strip %}
    {% if tl == 'selling-fast' or tl == 'selling fast' or tl == 'temusy-selling-fast' %}
      {% assign show_selling_fast = true %}
      {% break %}
    {% endif %}
  {% endfor %}
  {% if show_selling_fast == false %}
    {% if product.metafields.custom.selling_fast.value == true %}
      {% assign show_selling_fast = true %}
    {% endif %}
  {% endif %}

  {% assign carts_raw = product.metafields.custom.active_carts.value %}
  {% assign carts_n = carts_raw | plus: 0 %}
  {% assign show_carts = false %}
  {% if carts_raw != blank and carts_n > 0 %}
    {% assign show_carts = true %}
  {% endif %}

  {% assign show_row = false %}
  {% if pdp %}
    {% if pdp_has_low_stock or show_carts or show_selling_fast %}
      {% assign show_row = true %}
    {% endif %}
  {% elsif show_only_left or show_carts or show_selling_fast %}
    {% assign show_row = true %}
  {% endif %}

  {% if show_row %}
    <div
      class="productitem__urgency-badges{% if pdp %} product-urgency-engine product-urgency-engine--pdp{% endif %}"
      aria-label="{{ 'product.urgency.group_label' | t | escape }}"
    >
      {% if pdp %}
        {% for v in product.variants %}
          {% if v.inventory_management == 'shopify' and v.inventory_quantity != nil %}
            {% if v.inventory_quantity > 0 and v.inventory_quantity <= settings.low_stock_threshold %}
              <span
                class="productitem__urgency-badge productitem__urgency-badge--stock"
                data-stock-level
                data-stock-variant-id="{{ v.id }}"
                data-stock-variant-selected="{% if v.id == base_variant.id %}true{% else %}false{% endif %}"
              >
                {{- 'product.urgency.only_n_left' | t: count: v.inventory_quantity -}}
              </span>
            {% endif %}
          {% endif %}
        {% endfor %}
      {% elsif show_only_left %}
        <span class="productitem__urgency-badge productitem__urgency-badge--stock">
          {{- 'product.urgency.only_n_left' | t: count: only_left_n -}}
        </span>
      {% endif %}

      {% if show_carts %}
        <span class="productitem__urgency-badge productitem__urgency-badge--carts">
          {{- 'product.urgency.in_n_carts' | t: count: carts_n -}}
        </span>
      {% endif %}

      {% if show_selling_fast %}
        <span class="productitem__urgency-badge productitem__urgency-badge--velocity">
          {{- 'product.urgency.selling_fast' | t -}}
        </span>
      {% endif %}
    </div>
  {% endif %}
{% endif %}
