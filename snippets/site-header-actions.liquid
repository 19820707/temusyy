{% liquid
  assign mp_header = marketplace_header | default: false
%}

<ul class="site-header-actions" data-header-actions>
  {% if shop.customer_accounts_enabled %}
    {% unless customer %}
      <li class="site-header-actions__account-link">
        <a
          class="site-header_account-link-anchor{% if mp_header %} site-header_account-link-anchor--marketplace{% endif %}"
          href="{{ routes.account_login_url }}"
        >
          <span class="site-header__account-icon">
            {% 
                render 'icon-library', 
                id: 'icon-account', 
            %}
          </span>
          {% if mp_header %}
            <span class="site-header_account-link-text-stack">
              <span class="site-header_account-link-line1">{{ 'header.marketplace.welcome' | t }}</span>
              <span class="site-header_account-link-line2">{{ 'header.marketplace.sign_in_register' | t }}</span>
            </span>
          {% else %}
            <span class="site-header_account-link-text">
              {{ 'header.account.login' | t }}
            </span>
          {% endif %}
        </a>
      </li>
    {% else %}
      <li class="site-header-actions__account-link">
        <span class="site-header__account-icon">
          {% render 'icon-library', id: 'icon-account' %}
        </span>
        <span class="site-header__account-links">
          <a
            class="site-header__account-link--account"
            href="{{ routes.account_url }}"
          >
            {{ 'header.account.title' | t }}
          </a>
          
          <a
            class="site-header__account-link--logout"
            href="{{ routes.account_logout_url }}"
            data-no-instant
          >
            {{ 'header.account.logout' | t }}
          </a>
        </span>
      </li>
    {% endunless %}
  {% endif %}
</ul>
