{%- comment -%}
  invariant: Canonical storefront CSS lives in assets/theme.css; @font-face and :root --theme-font-* are emitted by snippets/theme-font-faces.liquid (rendered in layout before the theme.css stylesheet).
  invariant: This file is a thin shim so legacy or app references to theme.css.liquid still work; do not re-expand Liquid font_face blocks or duplicate theme.css here (Shopify asset compile cost, drift, double font loading).
{%- endcomment -%}

@import url('{{ "theme.css" | asset_url }}');
