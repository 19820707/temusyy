{% comment %}
  Temusy — Deal zone (marketplace-style dual rail): optional bundle lane, super-deals header with countdown + progress,
  horizontal SKU scroller with prev/next + keyboard. Timer: interval + visibility pause, theme editor lifecycle cleanup.
  Set "Deal end (ISO 8601)" for production; empty ISO uses rolling ~9h from render (demo). Copy must match real Shopify discounts.
{% endcomment %}
{% liquid
  assign col = section.settings.collection
  assign selected_collection = collections[col]
  assign product_count = section.settings.product_count | default: 6
  if selected_collection != blank
    assign product_count = product_count | at_most: selected_collection.products_count
  endif

  assign now_ts = 'now' | date: '%s' | plus: 0
  assign dl_raw = section.settings.deadline_iso | strip
  if dl_raw == blank
    assign deadline_ts = now_ts | plus: 32400
  else
    assign deadline_ts = dl_raw | date: '%s' | plus: 0
    if deadline_ts == blank or deadline_ts <= now_ts
      assign deadline_ts = now_ts | plus: 28800
    endif
  endif
  assign deadline_ms = deadline_ts | times: 1000
  assign initial_remaining_sec = deadline_ts | minus: now_ts
  if initial_remaining_sec < 1
    assign initial_remaining_sec = 1
  endif

  assign show_bundle_lane = section.settings.show_bundle_lane
  assign bundle_title = section.settings.bundle_title | strip
  assign bundle_line = section.settings.bundle_line | strip
  assign bundle_url = section.settings.bundle_link | strip
  if bundle_url == blank and selected_collection != blank
    assign bundle_url = selected_collection.url
  endif
  assign bundle_ready = false
  if show_bundle_lane and bundle_title != blank and bundle_url != blank
    assign bundle_ready = true
  endif

  assign deals_rail_title = section.settings.deals_rail_title | strip
  if deals_rail_title == blank
    assign deals_rail_title = 'sections.temusy_deal_zone.super_deals' | t
  endif

  assign scroller_id = 'temusy-deal-scroller-' | append: section.id
  assign scroller_label = 'sections.temusy_deal_zone.scroller_region' | t
  assign scroll_prev_label = 'sections.temusy_deal_zone.scroll_previous' | t
  assign scroll_next_label = 'sections.temusy_deal_zone.scroll_next' | t
  assign signal_one_label = section.settings.signal_one_label | strip
  assign signal_two_label = section.settings.signal_two_label | strip
  assign signal_three_label = section.settings.signal_three_label | strip
  assign signal_four_label = section.settings.signal_four_label | strip
%}

{% style %}
  #shopify-section-{{ section.id }} .temusy-deal-zone {
    --temusy-deal-bg: {{ section.settings.background_color }};
    --temusy-deal-accent: {{ section.settings.accent_color }};
    --temusy-deal-text: {{ section.settings.text_color }};
    --temusy-deal-surface: #ffffff;
    --temusy-deal-muted: rgba(15, 23, 42, 0.62);
    color-scheme: only light;
    background: var(--temusy-deal-bg);
    color: var(--temusy-deal-text);
    border-radius: 8px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 10px 40px rgba(15, 23, 42, 0.07);
    overflow: hidden;
    margin-left: auto;
    margin-right: auto;
    max-width: var(--layout-max-width, 1600px);
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__inner {
    padding: 1rem 0.85rem 1.15rem;
  }
  @media screen and (min-width: 720px) {
    #shopify-section-{{ section.id }} .temusy-deal-zone__inner {
      padding: 1.15rem 1.15rem 1.35rem;
    }
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__title {
    margin: 0 0 0.75rem;
    font-size: 1.15rem;
    font-weight: 900;
    letter-spacing: 0.02em;
    line-height: 1.2;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__signal-strip {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.45rem;
    margin: 0 0 0.8rem;
  }
  @media screen and (min-width: 860px) {
    #shopify-section-{{ section.id }} .temusy-deal-zone__signal-strip {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__signal {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2.35rem;
    padding: 0.45rem 0.6rem;
    border-radius: 8px;
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.08);
    color: var(--temusy-deal-text);
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.2;
    box-shadow: 0 1px 6px rgba(15, 23, 42, 0.04);
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__signal::before {
    content: "";
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 50%;
    background: var(--temusy-deal-accent);
    flex: 0 0 auto;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__signal:hover,
  #shopify-section-{{ section.id }} .temusy-deal-zone__signal:focus-visible {
    border-color: rgba(15, 23, 42, 0.18);
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__signal:focus-visible {
    outline: 2px solid var(--temusy-deal-accent);
    outline-offset: 2px;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__rails {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.65rem;
    margin-bottom: 0.75rem;
  }
  @media screen and (min-width: 720px) {
    #shopify-section-{{ section.id }} .temusy-deal-zone__rails--split {
      grid-template-columns: minmax(200px, 0.38fr) minmax(0, 1fr);
      gap: 0.85rem;
      align-items: stretch;
    }
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__rail {
    border-radius: 8px;
    background: var(--temusy-deal-surface);
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 2px 12px rgba(15, 23, 42, 0.05);
  }
  #shopify-section-{{ section.id }} a.temusy-deal-zone__rail--bundle {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.75rem 0.85rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} a.temusy-deal-zone__rail--bundle {
      transition: none;
    }
  }
  #shopify-section-{{ section.id }} a.temusy-deal-zone__rail--bundle:hover {
    border-color: rgba(15, 23, 42, 0.14);
    box-shadow: 0 4px 18px rgba(15, 23, 42, 0.08);
    transform: translateY(-1px);
  }
  @supports (color: color-mix(in srgb, red 50%, blue)) {
    #shopify-section-{{ section.id }} a.temusy-deal-zone__rail--bundle:hover {
      border-color: color-mix(in srgb, var(--temusy-deal-accent) 35%, transparent);
      box-shadow: 0 4px 18px color-mix(in srgb, var(--temusy-deal-accent) 18%, transparent);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} a.temusy-deal-zone__rail--bundle:hover {
      transform: none;
    }
  }
  #shopify-section-{{ section.id }} a.temusy-deal-zone__rail--bundle:focus-visible {
    outline: 2px solid var(--temusy-deal-accent);
    outline-offset: 2px;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__rail-icon {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: rgba(15, 23, 42, 0.06);
    color: var(--temusy-deal-accent);
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__rail-icon svg {
    width: 1.2rem;
    height: 1.2rem;
    display: block;
  }
  @supports (color: color-mix(in srgb, red 50%, blue)) {
    #shopify-section-{{ section.id }} .temusy-deal-zone__rail-icon {
      background: color-mix(in srgb, var(--temusy-deal-accent) 12%, transparent);
    }
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__rail-bundle-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__rail-bundle-text strong {
    font-size: 0.95rem;
    font-weight: 800;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__rail-bundle-text span {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--temusy-deal-muted);
    line-height: 1.3;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__rail-chev {
    margin-inline-start: auto;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--temusy-deal-accent);
    flex-shrink: 0;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__rail--deals {
    padding: 0.75rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    min-height: 100%;
    background: linear-gradient(180deg, #ffffff 0%, #fffdfb 100%);
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__deals-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem 0.75rem;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__deals-kicker {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--temusy-deal-accent);
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__countdown {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 700;
    color: rgba(15, 23, 42, 0.75);
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__clock {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    font-variant-numeric: tabular-nums;
    color: #ffffff;
    background: var(--temusy-deal-accent);
    padding: 0.28rem 0.55rem;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(15, 23, 42, 0.12);
    min-width: 6.5ch;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__progress {
    height: 3px;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.08);
    overflow: hidden;
    margin-top: 0.15rem;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__progress-bar {
    height: 100%;
    width: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.35) 0%, var(--temusy-deal-accent) 100%);
    transform-origin: left center;
    transform: scaleX(1);
    transition: transform 0.35s ease-out;
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .temusy-deal-zone__progress-bar {
      transition: none;
    }
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__expired {
    margin: 0;
    font-weight: 700;
    color: var(--temusy-deal-accent);
    font-size: 0.85rem;
  }
  #shopify-section-{{ section.id }} .temusy-deal-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    background: #fff;
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 1px 8px rgba(15, 23, 42, 0.06);
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .temusy-deal-card {
      transition: none;
    }
  }
  #shopify-section-{{ section.id }} .temusy-deal-card:hover {
    border-color: rgba(15, 23, 42, 0.14);
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.1);
    transform: translateY(-1px);
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .temusy-deal-card:hover {
      transform: none;
    }
  }
  #shopify-section-{{ section.id }} .temusy-deal-card:focus-visible {
    outline: 2px solid var(--temusy-deal-accent);
    outline-offset: 2px;
  }
  #shopify-section-{{ section.id }} .temusy-deal-card__media {
    position: relative;
    aspect-ratio: 1 / 1;
    background: rgba(15, 23, 42, 0.04);
  }
  #shopify-section-{{ section.id }} .temusy-deal-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #shopify-section-{{ section.id }} .temusy-deal-card__img--placeholder {
    object-fit: contain;
    padding: 0.85rem;
    opacity: 0.4;
  }
  #shopify-section-{{ section.id }} .temusy-deal-card__badge {
    position: absolute;
    top: 0.35rem;
    inset-inline-start: 0.35rem;
    z-index: 1;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.18rem 0.35rem;
    border-radius: 4px;
    color: #fff;
    background: var(--temusy-deal-accent);
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .temusy-deal-card__body {
    padding: 0.5rem 0.55rem 0.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.24rem;
    flex: 1;
    min-height: 0;
  }
  #shopify-section-{{ section.id }} .temusy-deal-card__vendor {
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: rgba(15, 23, 42, 0.52);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  #shopify-section-{{ section.id }} .temusy-deal-card__title {
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: var(--temusy-deal-text);
  }
  #shopify-section-{{ section.id }} .temusy-deal-card__price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.25rem 0.4rem;
    margin-top: auto;
  }
  #shopify-section-{{ section.id }} .temusy-deal-card__compare {
    font-size: 0.72rem;
    color: rgba(15, 23, 42, 0.45);
    text-decoration: line-through;
  }
  #shopify-section-{{ section.id }} .temusy-deal-card__from {
    font-size: 0.68rem;
    font-weight: 600;
    color: rgba(15, 23, 42, 0.55);
    margin-inline-end: 0.12rem;
    text-transform: lowercase;
  }
  #shopify-section-{{ section.id }} .temusy-deal-card__price {
    font-size: 0.96rem;
    font-weight: 800;
    color: var(--temusy-deal-text);
  }
  #shopify-section-{{ section.id }} .temusy-deal-card--sale .temusy-deal-card__price {
    color: var(--temusy-deal-accent);
  }
  #shopify-section-{{ section.id }} .temusy-deal-card__soldout {
    font-size: 0.68rem;
    font-weight: 700;
    color: rgba(15, 23, 42, 0.55);
  }
  #shopify-section-{{ section.id }} .temusy-deal-card__cta {
    margin-top: 0.1rem;
    color: var(--temusy-deal-accent);
    font-size: 0.72rem;
    font-weight: 900;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__scroller-shell {
    display: flex;
    align-items: stretch;
    gap: 0.35rem;
    margin-top: 0.15rem;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__scroller-nav {
    flex: 0 0 auto;
    width: 2.25rem;
    border-radius: 8px;
    border: 1px solid rgba(15, 23, 42, 0.1);
    background: var(--temusy-deal-surface);
    color: var(--temusy-deal-text);
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  @media screen and (min-width: 720px) {
    #shopify-section-{{ section.id }} .temusy-deal-zone__scroller-nav {
      display: flex;
    }
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__scroller-nav:hover {
    background: rgba(15, 23, 42, 0.04);
    border-color: rgba(15, 23, 42, 0.16);
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__scroller-nav:focus-visible {
    outline: 2px solid var(--temusy-deal-accent);
    outline-offset: 2px;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__scroller-nav:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__scroller {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 0.65rem;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.15rem 0 0.35rem;
    flex: 1 1 auto;
    min-width: 0;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: rgba(15, 23, 42, 0.22) transparent;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__scroller:focus-visible {
    outline: 2px solid var(--temusy-deal-accent);
    outline-offset: 2px;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__scroller::-webkit-scrollbar {
    height: 6px;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__scroller::-webkit-scrollbar-thumb {
    background: rgba(15, 23, 42, 0.18);
    border-radius: 999px;
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__scroller-cell {
    flex: 0 0 min(46vw, 210px);
    max-width: 240px;
    scroll-snap-align: start;
    align-self: stretch;
    display: flex;
    min-height: 0;
  }
  @media screen and (min-width: 720px) {
    #shopify-section-{{ section.id }} .temusy-deal-zone__scroller-cell {
      flex-basis: 200px;
    }
  }
  #shopify-section-{{ section.id }} .temusy-deal-zone__cta {
    margin-top: 0.85rem;
    text-align: center;
  }
{% endstyle %}

<div
  id="temusy-deal-zone-{{ section.id }}"
  class="temusy-deal-zone"
  data-section-type="dynamic-temusy-deal-zone"
  data-section-id="{{ section.id }}"
  data-temusy-deal-zone
  data-deadline-ms="{{ deadline_ms }}"
  data-initial-remaining-sec="{{ initial_remaining_sec }}"
  data-section-key="{{ section.id }}"
>
  <div class="temusy-deal-zone__inner">
    {% if section.settings.heading != blank %}
      <h2 class="temusy-deal-zone__title">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    {% if signal_one_label != blank or signal_two_label != blank or signal_three_label != blank or signal_four_label != blank %}
      <nav class="temusy-deal-zone__signal-strip" aria-label="{{ section.settings.signal_nav_label | escape }}">
        {% if signal_one_label != blank %}
          <a class="temusy-deal-zone__signal" href="{{ section.settings.signal_one_link | default: routes.all_products_collection_url }}">
            {{ signal_one_label | escape }}
          </a>
        {% endif %}
        {% if signal_two_label != blank %}
          <a class="temusy-deal-zone__signal" href="{{ section.settings.signal_two_link | default: routes.all_products_collection_url }}">
            {{ signal_two_label | escape }}
          </a>
        {% endif %}
        {% if signal_three_label != blank %}
          <a class="temusy-deal-zone__signal" href="{{ section.settings.signal_three_link | default: routes.all_products_collection_url }}">
            {{ signal_three_label | escape }}
          </a>
        {% endif %}
        {% if signal_four_label != blank %}
          <a class="temusy-deal-zone__signal" href="{{ section.settings.signal_four_link | default: routes.all_products_collection_url }}">
            {{ signal_four_label | escape }}
          </a>
        {% endif %}
      </nav>
    {% endif %}

    <div class="temusy-deal-zone__rails{% if bundle_ready %} temusy-deal-zone__rails--split{% endif %}">
      {% if bundle_ready %}
        <a
          class="temusy-deal-zone__rail temusy-deal-zone__rail--bundle"
          href="{{ bundle_url }}"
          aria-label="{{ bundle_title | escape }} - {{ bundle_line | escape }}"
        >
          <span class="temusy-deal-zone__rail-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
              <path d="M3 6h18"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
          </span>
          <span class="temusy-deal-zone__rail-bundle-text">
            <strong>{{ bundle_title | escape }}</strong>
            <span>{{ bundle_line | escape }}</span>
          </span>
          <span class="temusy-deal-zone__rail-chev" aria-hidden="true">›</span>
        </a>
      {% endif %}

      <div class="temusy-deal-zone__rail temusy-deal-zone__rail--deals">
        <div class="temusy-deal-zone__deals-head">
          <p class="temusy-deal-zone__deals-kicker">{{ deals_rail_title | escape }}</p>
          {% if section.settings.show_countdown %}
            <p class="temusy-deal-zone__countdown" data-temusy-deal-countdown-row>
              <span class="temusy-deal-zone__ends-label">{{ 'sections.temusy_deal_zone.ends_in' | t }}:</span>
              <time
                class="temusy-deal-zone__clock"
                data-temusy-deal-clock
                datetime=""
                aria-label="{{ 'sections.temusy_deal_zone.ends_in' | t }}"
              >00:00:00</time>
            </p>
          {% endif %}
        </div>
        {% if section.settings.show_countdown %}
          <div class="temusy-deal-zone__progress" aria-hidden="true" data-temusy-deal-progress-wrap>
            <div class="temusy-deal-zone__progress-bar" data-temusy-deal-progress></div>
          </div>
          <p class="temusy-deal-zone__expired" hidden data-temusy-deal-expired>{{ 'sections.temusy_deal_zone.expired' | t }}</p>
        {% endif %}
      </div>
    </div>

    {% if selected_collection != blank and product_count > 0 %}
      <div
        class="temusy-deal-zone__scroller-shell"
        role="region"
        aria-roledescription="carousel"
        aria-label="{{ scroller_label | escape }}"
      >
        <button
          type="button"
          class="temusy-deal-zone__scroller-nav temusy-deal-zone__scroller-nav--prev"
          data-temusy-deal-scroll="prev"
          aria-controls="{{ scroller_id }}"
          aria-label="{{ scroll_prev_label | escape }}"
        >
          ‹
        </button>
        <div
          id="{{ scroller_id }}"
          class="temusy-deal-zone__scroller"
          data-temusy-deal-grid
          data-temusy-intent-zone="buy"
          tabindex="0"
        >
          {% assign temusy_fc = selected_collection.handle %}
          {% for p in selected_collection.products limit: product_count %}
            <div class="temusy-deal-zone__scroller-cell">
              {% render 'temusy-deal-zone-card',
                product: p,
                collection: selected_collection,
                temusy_feedback_collection: temusy_fc,
                index: forloop.index
              %}
            </div>
          {% endfor %}
        </div>
        <button
          type="button"
          class="temusy-deal-zone__scroller-nav temusy-deal-zone__scroller-nav--next"
          data-temusy-deal-scroll="next"
          aria-controls="{{ scroller_id }}"
          aria-label="{{ scroll_next_label | escape }}"
        >
          ›
        </button>
      </div>
    {% endif %}

    {% if section.settings.cta_label != blank and selected_collection != blank and selected_collection.url != blank %}
      <div class="temusy-deal-zone__cta">
        <a class="button-{{ section.settings.cta_style }}" href="{{ selected_collection.url }}">
          {{- section.settings.cta_label | escape -}}
        </a>
      </div>
    {% endif %}
  </div>
</div>

{% if section.settings.show_countdown %}
  <script>
    (function () {
      var SECTION_ID = {{ section.id | json }};
      var ROOT_ID = 'temusy-deal-zone-' + SECTION_ID;

      function pad(n) {
        return String(n).padStart(2, '0');
      }

      function formatClock(sec) {
        var h = Math.floor(sec / 3600);
        var m = Math.floor((sec % 3600) / 60);
        var s = sec % 60;
        var hs = h < 100 ? pad(h) : String(h);
        return hs + ':' + pad(m) + ':' + pad(s);
      }

      function isoFromMs(ms) {
        try {
          return new Date(ms).toISOString();
        } catch (e) {
          return '';
        }
      }

      function mount(root) {
        if (!root || root.getAttribute('data-temusy-deal-mounted') === '1') return;
        var endMs = Number(root.getAttribute('data-deadline-ms')) || 0;
        var initialSec = Number(root.getAttribute('data-initial-remaining-sec')) || 1;
        var clockEl = root.querySelector('[data-temusy-deal-clock]');
        var rowEl = root.querySelector('[data-temusy-deal-countdown-row]');
        var expiredEl = root.querySelector('[data-temusy-deal-expired]');
        var progressEl = root.querySelector('[data-temusy-deal-progress]');
        var wrapEl = root.querySelector('[data-temusy-deal-progress-wrap]');
        if (!clockEl || !endMs) return;

        root.setAttribute('data-temusy-deal-mounted', '1');

        var reduceMotion =
          typeof window.matchMedia === 'function' &&
          window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        var scroller = root.querySelector('[data-temusy-deal-grid]');
        var btnPrev = root.querySelector('[data-temusy-deal-scroll="prev"]');
        var btnNext = root.querySelector('[data-temusy-deal-scroll="next"]');

        var tickId = null;
        var destroyed = false;

        function setProgress(remainingSec) {
          if (!progressEl || !wrapEl) return;
          var p = Math.max(0, Math.min(1, remainingSec / initialSec));
          progressEl.style.transform = 'scaleX(' + p + ')';
        }

        function updateNavDisabled() {
          if (!scroller || !btnPrev || !btnNext) return;
          var maxScroll = scroller.scrollWidth - scroller.clientWidth - 2;
          if (maxScroll <= 0) {
            btnPrev.disabled = true;
            btnNext.disabled = true;
            return;
          }
          btnPrev.disabled = scroller.scrollLeft <= 2;
          btnNext.disabled = scroller.scrollLeft >= maxScroll - 2;
        }

        function scrollByDir(dir) {
          if (!scroller) return;
          var cell = scroller.querySelector('.temusy-deal-zone__scroller-cell');
          var delta = cell ? Math.max(120, cell.offsetWidth + 12) : 220;
          scroller.scrollBy({
            left: dir * delta,
            behavior: reduceMotion ? 'auto' : 'smooth',
          });
        }

        function onScrollNavClick(ev) {
          var t = ev.currentTarget;
          var dir = t.getAttribute('data-temusy-deal-scroll') === 'prev' ? -1 : 1;
          scrollByDir(dir);
        }

        function onScrollerKeydown(ev) {
          if (ev.key === 'ArrowLeft') {
            ev.preventDefault();
            scrollByDir(-1);
          } else if (ev.key === 'ArrowRight') {
            ev.preventDefault();
            scrollByDir(1);
          }
        }

        if (btnPrev) btnPrev.addEventListener('click', onScrollNavClick);
        if (btnNext) btnNext.addEventListener('click', onScrollNavClick);
        if (scroller) {
          scroller.addEventListener('scroll', updateNavDisabled, { passive: true });
          scroller.addEventListener('keydown', onScrollerKeydown);
        }

        function tick() {
          if (destroyed || document.hidden) return;
          var now = Date.now();
          var sec = Math.max(0, Math.floor((endMs - now) / 1000));
          if (sec <= 0) {
            clockEl.textContent = '00:00:00';
            clockEl.setAttribute('datetime', isoFromMs(endMs));
            if (rowEl) rowEl.setAttribute('hidden', 'hidden');
            if (wrapEl) wrapEl.setAttribute('hidden', 'hidden');
            if (expiredEl) expiredEl.removeAttribute('hidden');
            setProgress(0);
            if (tickId != null) {
              window.clearInterval(tickId);
              tickId = null;
            }
            return;
          }
          clockEl.textContent = formatClock(sec);
          clockEl.setAttribute('datetime', isoFromMs(now + sec * 1000));
          setProgress(sec);
        }

        function onVisibility() {
          if (!document.hidden) tick();
        }

        tick();
        tickId = window.setInterval(tick, 1000);
        document.addEventListener('visibilitychange', onVisibility);
        window.addEventListener('resize', updateNavDisabled);
        if (scroller) {
          window.requestAnimationFrame(updateNavDisabled);
        }

        root._temusyDealDestroy = function () {
          destroyed = true;
          if (tickId != null) window.clearInterval(tickId);
          document.removeEventListener('visibilitychange', onVisibility);
          window.removeEventListener('resize', updateNavDisabled);
          if (btnPrev) btnPrev.removeEventListener('click', onScrollNavClick);
          if (btnNext) btnNext.removeEventListener('click', onScrollNavClick);
          if (scroller) {
            scroller.removeEventListener('scroll', updateNavDisabled);
            scroller.removeEventListener('keydown', onScrollerKeydown);
          }
          root.removeAttribute('data-temusy-deal-mounted');
          delete root._temusyDealDestroy;
        };
      }

      function tryMountFromDom() {
        var root = document.getElementById(ROOT_ID);
        if (root) mount(root);
      }

      function onSectionLifecycle(ev) {
        var d = ev.detail || {};
        if (String(d.sectionId) !== String(SECTION_ID)) return;
        var wrap = document.getElementById('shopify-section-' + SECTION_ID);
        if (!wrap) return;
        var root = wrap.querySelector('[data-temusy-deal-zone]');
        if (ev.type === 'shopify:section:unload') {
          if (root && root._temusyDealDestroy) root._temusyDealDestroy();
          return;
        }
        if (ev.type === 'shopify:section:load') {
          if (root && root._temusyDealDestroy) root._temusyDealDestroy();
          mount(root);
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', tryMountFromDom);
      } else {
        tryMountFromDom();
      }
      document.addEventListener('shopify:section:load', onSectionLifecycle);
      document.addEventListener('shopify:section:unload', onSectionLifecycle);
    })();
  </script>
{% elsif selected_collection != blank and product_count > 0 %}
  <script>
    (function () {
      var SECTION_ID = {{ section.id | json }};
      var ROOT_ID = 'temusy-deal-zone-' + SECTION_ID;

      function mountScrollerOnly(root) {
        if (!root || root.getAttribute('data-temusy-deal-scroll-mounted') === '1') return;
        var reduceMotion =
