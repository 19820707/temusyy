        };
      }

      function tryMount() {
        var root = document.getElementById(ROOT_ID);
        if (root) mountScrollerOnly(root);
      }

      function onSectionLifecycle(ev) {
        var d = ev.detail || {};
        if (String(d.sectionId) !== String(SECTION_ID)) return;
        var wrap = document.getElementById('shopify-section-' + SECTION_ID);
        if (!wrap) return;
        var root = wrap.querySelector('[data-temusy-deal-zone]');
        if (ev.type === 'shopify:section:unload') {
          if (root && root._temusyDealScrollDestroy) root._temusyDealScrollDestroy();
          return;
        }
        if (ev.type === 'shopify:section:load') {
          if (root && root._temusyDealScrollDestroy) root._temusyDealScrollDestroy();
          mountScrollerOnly(root);
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', tryMount);
      } else {
        tryMount();
      }
      document.addEventListener('shopify:section:load', onSectionLifecycle);
      document.addEventListener('shopify:section:unload', onSectionLifecycle);
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Today's deals (countdown)",
  "tag": "section",
  "class": "shopify-section--temusy-deal-zone",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Today's deals"
    },
    {
      "type": "header",
      "content": "Marketplace signal strip"
    },
    {
      "type": "text",
      "id": "signal_nav_label",
      "label": "Signal strip accessibility label",
      "default": "Shopping benefits"
    },
    {
      "type": "text",
      "id": "signal_one_label",
      "label": "Signal 1 label",
      "default": "Choice picks"
    },
    {
      "type": "url",
      "id": "signal_one_link",
      "label": "Signal 1 link"
    },
    {
      "type": "text",
      "id": "signal_two_label",
      "label": "Signal 2 label",
      "default": "Bundle savings"
    },
    {
      "type": "url",
      "id": "signal_two_link",
      "label": "Signal 2 link"
    },
    {
      "type": "text",
      "id": "signal_three_label",
      "label": "Signal 3 label",
      "default": "Secure checkout"
    },
    {
      "type": "url",
      "id": "signal_three_link",
      "label": "Signal 3 link"
    },
    {
      "type": "text",
      "id": "signal_four_label",
      "label": "Signal 4 label",
      "default": "Support ready"
    },
    {
      "type": "url",
      "id": "signal_four_link",
      "label": "Signal 4 link"
    },
    {
      "type": "header",
      "content": "Bundle rail (left)"
    },
    {
      "type": "checkbox",
      "id": "show_bundle_lane",
      "label": "Show bundle lane",
      "default": true,
      "info": "AliExpress-style left tile: drive multi-qty / bundle traffic. Link to a collection or policy page; keep copy aligned with real checkout rules."
    },
    {
      "type": "text",
      "id": "bundle_title",
      "label": "Bundle lane title",
      "default": "Bundle deals"
    },
    {
      "type": "textarea",
      "id": "bundle_line",
      "label": "Bundle lane line",
      "default": "3+ items - stack savings at checkout when your discount applies."
    },
    {
      "type": "url",
      "id": "bundle_link",
      "label": "Bundle lane link",
      "info": "If empty, uses the same collection as the product scroller."
    },
    {
      "type": "header",
      "content": "Super deals rail (right)"
    },
    {
      "type": "text",
      "id": "deals_rail_title",
      "label": "Deals rail kicker",
      "default": "",
      "info": "Short uppercase label beside the timer (leave blank to use translation “Super deals”)."
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Show live countdown",
      "default": true
    },
    {
      "type": "text",
      "id": "deadline_iso",
      "label": "Deal end (ISO 8601)",
      "default": "",
      "info": "Leave empty for a rolling ~9h demo window from each page view. For production, set a real end, e.g. 2026-04-20T21:00:00 or 2026-04-20T21:00:00+01:00. If the date is in the past, the theme adds 8 hours from load as a fallback."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Deal products"
    },
    {
      "type": "range",
      "id": "product_count",
      "min": 4,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 8
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "View all deals"
    },
    {
      "type": "select",
      "id": "cta_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#f1f5f9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#0f172a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (countdown pill + highlights)",
      "default": "#e11d48"
    }
  ],
  "presets": [
    {
      "name": "Today's deals (countdown)"
    }
  ]
}
{% endschema %}
