{% comment %}
  When `request.cookies.temusy_interest` matches a real collection handle, surface a compact product
  strip above the rest of the homepage flow (see templates/index.json order). Empty when no cookie
  or unknown handle — keeps first paint lean for new visitors.
{% endcomment %}
{% liquid
  assign interest_raw = request.cookies.temusy_interest | default: '' | strip | downcase
  assign focused_collection = blank
  if interest_raw != blank
    assign focused_collection = collections[interest_raw]
  endif
%}

{% if focused_collection != blank and focused_collection.products_count > 0 %}
  <div
    class="adaptive-homepage-priority adaptive-homepage-priority--{{ section.id }}"
    data-adaptive-priority
    {{ section.shopify_attributes }}
  >
    <div class="adaptive-homepage-priority__inner">
      <header class="adaptive-homepage-priority__header">
        <div>
          <h2 class="adaptive-homepage-priority__title">
            {{ section.settings.heading | escape }}
          </h2>
          {% if section.settings.subheading != blank %}
            <p class="adaptive-homepage-priority__sub">{{ section.settings.subheading | escape }}</p>
          {% endif %}
        </div>
        <div class="adaptive-homepage-priority__actions">
          {% liquid
            assign adaptive_cta_text = section.settings.cta_label | replace: '[[collection]]', focused_collection.title
          %}
          <a class="adaptive-homepage-priority__cta" href="{{ focused_collection.url }}">
            {{ adaptive_cta_text | escape }}
          </a>
          {% if section.settings.show_clear %}
            <button
              type="button"
              class="adaptive-homepage-priority__clear"
              data-temusy-clear-interest
            >
              {{ 'general.adaptive.clear' | t }}
            </button>
          {% endif %}
        </div>
      </header>

      <div
        class="
          productgrid--items
          products-per-row-{{- section.settings.products_per_row -}}
          adaptive-homepage-priority__grid
        "
      >
        {% for product in focused_collection.products limit: section.settings.product_limit %}
          {%
            render 'product-grid-item',
            product: product,
            context: 'collection',
            index: forloop.index,
            products_per_row: section.settings.products_per_row,
            temusy_feedback_collection: focused_collection.handle,
          %}
        {% endfor %}
      </div>
    </div>
  </div>

  {% style %}
    .adaptive-homepage-priority--{{ section.id }} {
      --ta-accent: {{ settings.color_links }};
      --ta-heading: {{ settings.color_headings }};
      --ta-body: {{ settings.color_text }};
      --ta-surface: {{ settings.color_input_background }};
      --ta-border: {{ settings.color_input_border }};
      --ta-btn-bg: {{ settings.color_button_background }};
      --ta-btn-fg: {{ settings.color_button_text }};
      background: {{ settings.color_background }};
      border-bottom: 1px solid var(--ta-border);
      font-family: var(--theme-font-body), sans-serif;
      padding: 16px 14px 20px;
    }
    .adaptive-homepage-priority--{{ section.id }} .adaptive-homepage-priority__inner {
      margin: 0 auto;
      max-width: 1280px;
    }
    .adaptive-homepage-priority--{{ section.id }} .adaptive-homepage-priority__header {
      align-items: flex-start;
      display: flex;
      flex-wrap: wrap;
      gap: 10px 16px;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .adaptive-homepage-priority--{{ section.id }} .adaptive-homepage-priority__title {
      color: var(--ta-heading);
      font-family: var(--theme-font-heading), sans-serif;
      font-size: 1.25rem;
      line-height: 1.2;
      margin: 0;
    }
    .adaptive-homepage-priority--{{ section.id }} .adaptive-homepage-priority__sub {
      color: var(--ta-body);
      font-size: 0.95rem;
      margin: 4px 0 0;
      max-width: 60ch;
    }
    .adaptive-homepage-priority--{{ section.id }} .adaptive-homepage-priority__actions {
      align-items: center;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .adaptive-homepage-priority--{{ section.id }} .adaptive-homepage-priority__cta {
      background: var(--ta-btn-bg);
      border-radius: 6px;
      color: var(--ta-btn-fg);
      font-family: var(--theme-font-button), sans-serif;
      font-weight: 700;
      padding: 8px 14px;
      text-decoration: none;
    }
    .adaptive-homepage-priority--{{ section.id }} .adaptive-homepage-priority__cta:focus-visible {
      outline: 2px solid var(--ta-accent);
      outline-offset: 2px;
    }
    .adaptive-homepage-priority--{{ section.id }} .adaptive-homepage-priority__clear {
      background: var(--ta-surface);
      border: 1px solid var(--ta-border);
      border-radius: 6px;
      color: var(--ta-heading);
      cursor: pointer;
      font-weight: 600;
      padding: 8px 12px;
    }
    .adaptive-homepage-priority--{{ section.id }} .adaptive-homepage-priority__clear:focus-visible {
      outline: 2px solid var(--ta-accent);
      outline-offset: 2px;
    }
  {% endstyle %}
{% endif %}

{% schema %}
{
  "name": "Adaptive homepage priority",
  "tag": "section",
  "class": "adaptive-homepage-priority-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Continue here"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": ""
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Collection CTA label",
      "default": "View full [[collection]]",
      "info": "Use [[collection]] for the matched collection title."
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Products per row (desktop)"
    },
    {
      "type": "checkbox",
      "id": "show_clear",
      "label": "Show reset control",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Adaptive homepage priority"
    }
  ]
}
{% endschema %}
