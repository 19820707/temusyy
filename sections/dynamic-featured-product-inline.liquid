{% comment %}
  First-viewport product discovery: a tight row of real SKUs from one collection (no slideshow chrome).
  Theme JSON type: dynamic-featured-product-inline (maps to the “featured-product-inline” pattern).
{% endcomment %}
{% liquid
  assign selected_collection = collections[section.settings.collection]
  assign show_count = section.settings.limit | default: 3
  if show_count < 2
    assign show_count = 2
  endif
  if show_count > 6
    assign show_count = 6
  endif
%}

{% if selected_collection != blank and selected_collection.products_count > 0 %}
  <section
    class="featured-product-inline featured-product-inline--{{ section.id }}"
    data-featured-product-inline
    data-temusy-intent-zone="buy"
    {{ section.shopify_attributes }}
  >
    <div class="featured-product-inline__inner">
      {% if section.settings.heading != blank or section.settings.show_collection_link %}
        <header class="featured-product-inline__head">
          {% if section.settings.heading != blank %}
            <h2 class="featured-product-inline__title">{{ section.settings.heading | escape }}</h2>
          {% endif %}
          {% if section.settings.show_collection_link and selected_collection.url != blank %}
            <a class="featured-product-inline__all" href="{{ selected_collection.url }}">
              {{ section.settings.collection_link_label | escape }}
            </a>
          {% endif %}
        </header>
      {% endif %}

      <div
        class="
          featured-product-inline__grid
          productgrid--items
          products-per-row-{{- show_count -}}
        "
      >
        {% for product in selected_collection.products limit: show_count %}
          {%
            render 'product-grid-item',
            product: product,
            collection: selected_collection,
            context: 'collection',
            index: forloop.index,
            products_per_row: show_count,
          %}
        {% endfor %}
      </div>
    </div>
  </section>

  {% style %}
    .featured-product-inline--{{ section.id }} {
      --tf-accent: {{ settings.color_links }};
      --tf-heading: {{ settings.color_headings }};
      --tf-surface: {{ settings.color_input_background }};
      --tf-border: {{ settings.color_input_border }};
      background: {{ settings.color_background }};
      border-bottom: 1px solid var(--tf-border);
      font-family: var(--theme-font-body), sans-serif;
      padding: 12px 16px 20px;
    }
    .featured-product-inline--{{ section.id }} .featured-product-inline__inner {
      margin: 0 auto;
      max-width: 1280px;
    }
    .featured-product-inline--{{ section.id }} .featured-product-inline__head {
      align-items: baseline;
      display: flex;
      flex-wrap: wrap;
      gap: 8px 16px;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .featured-product-inline--{{ section.id }} .featured-product-inline__title {
      color: var(--tf-heading);
      font-family: var(--theme-font-heading), sans-serif;
      font-size: 1rem;
      font-weight: 800;
      line-height: 1.2;
      margin: 0;
    }
    .featured-product-inline--{{ section.id }} .featured-product-inline__all {
      color: var(--tf-accent);
      font-size: 0.9rem;
      font-weight: 700;
      text-decoration: none;
      white-space: nowrap;
    }
    .featured-product-inline--{{ section.id }} .featured-product-inline__all:hover,
    .featured-product-inline--{{ section.id }} .featured-product-inline__all:focus-visible {
      text-decoration: underline;
    }
    .featured-product-inline--{{ section.id }} .featured-product-inline__all:focus-visible {
      outline: 2px solid var(--tf-accent);
      outline-offset: 2px;
    }
    .featured-product-inline--{{ section.id }} .featured-product-inline__grid {
      margin: 0;
    }
  {% endstyle %}
{% endif %}

{% schema %}
{
  "name": "Featured product inline",
  "tag": "section",
  "class": "featured-product-inline-section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "Products to show"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Popular right now"
    },
    {
      "type": "checkbox",
      "id": "show_collection_link",
      "label": "Show link to full collection",
      "default": true
    },
    {
      "type": "text",
      "id": "collection_link_label",
      "label": "Collection link label",
      "default": "View all"
    }
  ],
  "presets": [
    {
      "name": "Featured product inline"
    }
  ]
}
{% endschema %}
