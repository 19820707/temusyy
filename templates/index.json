      "type": "dynamic-testimonials",
      "blocks": {
        "testimonial-1": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/man-reaches-inside-his-jacket.jpg",
            "star_rating": "5",
            "text": "<p><strong>An elegant and reliable watch, clearly crafted to last. Prompt delivery and refined packaging added to a smooth, premium experience. Highly recommended for those who appreciate quality and style.</strong></p>",
            "author": "<p><em><strong>Jonathan Reed</strong></em></p>"
          }
        },
        "testimonial-2": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/loafers-leaning-along-white-wall.jpg",
            "star_rating": "5",
            "text": "<p><strong>Impressive quality and classic design. These loafers are as comfortable as they are stylish. The unboxing experience matched the premium look and feel.</strong></p>",
            "author": "<p><em><strong>Oliver Grant</strong></em></p>"
          }
        },
        "testimonial-3": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/woman-listening-to-music.jpg",
            "star_rating": "5",
            "text": "<p><strong>Crisp sound, seamless Bluetooth connection, and a comfortable fit. These earbuds exceeded expectations. Delivery was prompt and packaging felt premium.</strong></p>",
            "author": "<p><em><strong>Sophia Lane</strong></em></p>"
          }
        },
        "testimonial-4": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/pink-lip-gloss.jpg",
            "star_rating": "5",
            "text": "<p><strong>A modern, refined scent that works perfectly for day or evening. The fragrance has depth and longevity. Excellent customer care and presentation.</strong></p>",
            "author": "<p><em><strong>Alex Whitmore</strong></em></p>"
          }
        }
      },
